    <ItemGroup>
        <None Include="App.config"/>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="NPinyin.Core" Version="3.0.0"/>
    </ItemGroup>
    <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets"/>
    <!-- 生成后将 hfa_model / ASR ONNX / onnxruntime 等复制到运行目录 -->
    <PropertyGroup>
        <HfaModelSource>$(ProjectDir)..\..\hfa_model</HfaModelSource>
        <OnnxRuntimeDll>$(ProjectDir)..\..\Microsoft.ML.OnnxRuntime.DirectML.1.21.0\runtimes\win-x64\native\onnxruntime.dll</OnnxRuntimeDll>
        <OnnxRuntimeSharedDll></OnnxRuntimeSharedDll>
        <!-- ASR 纯 ONNX 模型目录（andrewleech 导出格式） -->
        <AsrOnnxModelSource>$(ProjectDir)..\..\qwen3-asr-1.7b-onnx</AsrOnnxModelSource>
        <!-- GAME ONNX 模型目录 -->
        <GameOnnxModelSource>$(ProjectDir)..\..\Game\GAME-1.0.3-large-onnx</GameOnnxModelSource>
        <!-- Go 后端 exe -->
        <GoExeSource>$(ProjectDir)..\..\DataForgeLite.exe</GoExeSource>
        <GoExeSourceCmd>$(ProjectDir)..\..\cmd\DataForgeLite.exe</GoExeSourceCmd>
    </PropertyGroup>
    <!-- 复制 hfa_model 到运行目录，供 Go 后端 FA 推理使用 -->
    <Target Name="CopyHfaModelToOutput" AfterTargets="Build" Condition="Exists('$(HfaModelSource)')">
        <Message Importance="high" Text="正在复制 hfa_model 到 $(OutputPath)hfa_model ..."/>
        <Exec Command="robocopy &quot;$(HfaModelSource)&quot; &quot;$(OutputPath)hfa_model&quot; /E /IS /IT /NFL /NDL /NJH /NJS"
              IgnoreExitCode="true"
              WorkingDirectory="$(ProjectDir)"/>
    </Target>
    <!-- 只复制 onnxruntime.dll 和 onnxruntime_providers_shared.dll，不复制 headers/docs -->
    <Target Name="CopyOnnxRuntimeToOutput" AfterTargets="Build" Condition="Exists('$(OnnxRuntimeDll)')">
        <Message Importance="high" Text="正在复制 onnxruntime DLL 到 $(OutputPath) ..."/>
        <Copy SourceFiles="$(OnnxRuntimeDll)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true"/>
        <Copy SourceFiles="$(OnnxRuntimeSharedDll)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true"
              Condition="Exists('$(OnnxRuntimeSharedDll)')"/>
        <!-- 复制 DirectML DLL（仅 directml 版本包含） -->
        <Copy SourceFiles="$(ProjectDir)..\..\Microsoft.ML.OnnxRuntime.DirectML.1.21.0\runtimes\win-x64\native\onnxruntime.dll"
              DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true"
              Condition="Exists('$(ProjectDir)..\..\Microsoft.ML.OnnxRuntime.DirectML.1.21.0\runtimes\win-x64\native\onnxruntime.dll')"/>
    </Target>
    <!-- 复制 ASR ONNX 模型目录到输出目录，供纯 Go ASR 使用 -->
    <Target Name="CopyAsrOnnxModelToOutput" AfterTargets="Build" Condition="Exists('$(AsrOnnxModelSource)\encoder.onnx')">
        <Message Importance="high" Text="正在复制 ASR ONNX 模型 (qwen3-asr-1.7b-onnx) 到 $(OutputPath)qwen3-asr-1.7b-onnx ..."/>
        <Exec Command="robocopy &quot;$(AsrOnnxModelSource)&quot; &quot;$(OutputPath)qwen3-asr-1.7b-onnx&quot; /E /IS /IT /XD .git /NFL /NDL /NJH /NJS"
              IgnoreExitCode="true"
              WorkingDirectory="$(ProjectDir)"/>
    </Target>
    <!-- 复制 GAME ONNX 模型目录到输出目录，供 GAME 推理使用 -->
    <Target Name="CopyGameOnnxModelToOutput" AfterTargets="Build" Condition="Exists('$(GameOnnxModelSource)\config.json')">
        <Message Importance="high" Text="正在复制 GAME ONNX 模型 (GAME-1.0.3-large-onnx) 到 $(TargetDir)Gameonnx ..."/>
        <MakeDir Directories="$(TargetDir)Gameonnx" />
        <Exec Command="robocopy &quot;$(GameOnnxModelSource)&quot; &quot;$(TargetDir)Gameonnx&quot; /E /IS /IT /XD .git /NFL /NDL /NJH /NJS"
              IgnoreExitCode="true"
              WorkingDirectory="$(ProjectDir)"/>
    </Target>
    <!-- 编译 Go 后端并复制 DataForgeLite.exe 到输出目录 -->
    <Target Name="BuildAndCopyGoExe" AfterTargets="Build">
        <Message Importance="high" Text="正在编译 Go 后端 DataForgeLite.exe ..."/>
        <Exec Command="cmd /c &quot;set CGO_ENABLED=1&amp;&amp; set PATH=%PATH%;C:\Users\a1584\AppData\Local\Microsoft\WinGet\Packages\MartinStorsjo.LLVM-MinGW.UCRT_Microsoft.Winget.Source_8wekyb3d8bbwe\llvm-mingw-20260311-ucrt-x86_64\bin&amp;&amp; go build -o ..\..\DataForgeLite.exe .\cmd\&quot;"
              WorkingDirectory="$(ProjectDir)..\.."
              IgnoreExitCode="false"/>
        <Message Importance="high" Text="正在复制 DataForgeLite.exe 到 $(OutputPath) ..."/>
        <Copy SourceFiles="$(GoExeSource)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="false"/>
    </Target>
</Project>