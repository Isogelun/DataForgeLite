<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="DataForgeLiteClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataForgeLiteClient"
        mc:Ignorable="d"
        Title="DataForge Lite"
        Width="1440"
        Height="900"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F6FB"
        FontFamily="Microsoft YaHei, Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#FF2563EB"/>
        <SolidColorBrush x:Key="Success" Color="#FF059669"/>
        <SolidColorBrush x:Key="TextMain" Color="#FF111827"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FF6B7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FFE5E7EB"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Success}"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF9FAFB"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF3F4F6"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF111827" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource Primary}" Margin="0,0,12,0">
                        <TextBlock Text="DF" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="DataForge Lite" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtHeaderSubtitle" Text="按流程页签操作：导入 → 预处理/切分 → ASR → 校正 → 导出" Foreground="#FF9CA3AF" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="推理设备:" VerticalAlignment="Center" Foreground="White" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbOrtDevice" Width="100" Height="28" VerticalContentAlignment="Center" SelectedIndex="0" SelectionChanged="CmbOrtDevice_SelectionChanged" ToolTip="CPU：兼容所有设备；DML：DirectML GPU 加速（需 onnxruntime-win-x64-gpu）">
                        <ComboBoxItem Content="CPU" Tag="cpu"/>
                        <ComboBoxItem Content="DML (GPU)" Tag="dml"/>
                    </ComboBox>
                    <ComboBox x:Name="CmbDmlDeviceId" Width="140" Height="28" VerticalContentAlignment="Center" Margin="6,0,0,0" Visibility="Collapsed" ToolTip="选择 DirectML GPU 设备"/>
                    <Button x:Name="BtnGoImport" Style="{StaticResource GhostButton}" Content="导入音频" Width="90" Margin="16,0,0,0" Click="BtnGoImport_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="16" Style="{StaticResource CardStyle}">
            <TabControl x:Name="TabMain" TabStripPlacement="Top" SelectedIndex="0">
                <TabItem Header="项目概览">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="130"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="项目总览" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,0,0,16"/>

                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="音频文件数" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock x:Name="TxtStatAudioCount" Text="0" FontSize="30" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="总时长" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock x:Name="TxtStatDuration" Text="00:00:00" FontSize="30" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="切片数量" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock x:Name="TxtStatSliceCount" Text="0" FontSize="30" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="当前进度" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock x:Name="TxtStatProgress" Text="0%" FontSize="30" FontWeight="Bold" Foreground="{StaticResource Success}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="处理流程" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <ProgressBar x:Name="ProgressFlow" Height="18" Value="0" Maximum="100" Margin="0,0,0,12"/>
                                    <TextBlock x:Name="TxtProgressDesc" Text="请选择文件夹导入音频或直接填写各步骤路径" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="最近日志" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <ListBox x:Name="ListLogs" BorderThickness="0" ItemsSource="{Binding Logs}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="音频导入">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="音频导入" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                        <Border x:Name="DropZoneAudio" Grid.Row="1" Style="{StaticResource CardStyle}" BorderBrush="#FF93C5FD" BorderThickness="2" Background="#FFF8FBFF"
                                AllowDrop="True" DragOver="DropZoneAudio_DragOver" Drop="DropZoneAudio_Drop">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="拖拽音频文件到这里" FontSize="26" FontWeight="SemiBold" Foreground="#FF1D4ED8" HorizontalAlignment="Center"/>
                                <TextBlock Text="支持 WAV / MP3 / FLAC / M4A / OGG" Foreground="{StaticResource TextMuted}" Margin="0,8,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnSelectFiles" Style="{StaticResource PrimaryButton}" Content="选择文件" Width="120" Margin="0,0,8,0" Click="BtnSelectFiles_Click"/>
                                    <Button x:Name="BtnSelectFolder" Style="{StaticResource GhostButton}" Content="选择文件夹" Width="120" Margin="0,0,8,0" Click="BtnSelectFolder_Click"/>
                                    <Button x:Name="BtnClearAudioList" Style="{StaticResource GhostButton}" Content="清空列表" Width="120" Click="BtnClearAudioList_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,16,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="已导入文件列表" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtSearchAudio" Height="32" VerticalContentAlignment="Center" Text="" TextChanged="TxtSearchAudio_TextChanged"/>
                        </Grid>

                        <DataGrid x:Name="GridAudioFiles" Grid.Row="3" ItemsSource="{Binding AudioFiles}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="文件名" Width="2.5*" Binding="{Binding FileName}"/>
                                <DataGridTextColumn Header="格式" Width="0.8*" Binding="{Binding Format}"/>
                                <DataGridTextColumn Header="时长" Width="0.9*" Binding="{Binding Duration}"/>
                                <DataGridTextColumn Header="采样率" Width="0.9*" Binding="{Binding SampleRate}"/>
                                <DataGridTextColumn Header="状态" Width="0.9*" Binding="{Binding Status}"/>
                                <DataGridTextColumn Header="备注" Width="1.8*" Binding="{Binding Note}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="预处理 / 切分">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="预处理与切分" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="BtnPreprocess" Style="{StaticResource PrimaryButton}" Content="开始预处理" Width="120" Margin="0,0,8,0" Click="BtnPreprocess_Click"/>
                                    <Button x:Name="BtnSplit" Style="{StaticResource SuccessButton}" Content="开始切分" Width="120" Margin="0,0,8,0" Click="BtnSplit_Click"/>
                                </StackPanel>
                                <Border Height="120" Background="#FFEEF2FF" CornerRadius="8" BorderBrush="#FFDBEAFE" BorderThickness="1" Margin="0,0,0,12">
                                    <TextBlock x:Name="TxtPreprocessStatus" Text="预处理与切分需先选择文件夹导入音频；输入为工作目录，输出为 preprocessed / slices" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="12" VerticalAlignment="Center"/>
                                </Border>
                                <DataGrid x:Name="GridSlices" ItemsSource="{Binding Slices}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="切片编号" Width="1*" Binding="{Binding SliceId}"/>
                                        <DataGridTextColumn Header="开始" Width="1*" Binding="{Binding Start}"/>
                                        <DataGridTextColumn Header="结束" Width="1*" Binding="{Binding End}"/>
                                        <DataGridTextColumn Header="时长" Width="1*" Binding="{Binding Duration}"/>
                                        <DataGridTextColumn Header="状态" Width="1*" Binding="{Binding Status}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="处理参数" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="目标响度 (LUFS)" Foreground="{StaticResource TextMuted}"/>
                                <TextBox x:Name="TxtTargetLufs" Height="32" Text="-18" Margin="0,4,0,10" ToolTip="响度均衡目标，如 -18"/>
                                <TextBlock Text="最大真峰 (dB)" Foreground="{StaticResource TextMuted}"/>
                                <TextBox x:Name="TxtTruePeakLimit" Height="32" Text="-1" Margin="0,4,0,10" ToolTip="限制峰值上限防爆音，如 -1 或 -3"/>
                                <TextBlock Text="采样率" Foreground="{StaticResource TextMuted}"/>
                                <ComboBox Height="32" SelectedIndex="0" Margin="0,4,0,10">
                                    <ComboBoxItem Content="48000 Hz"/>
                                    <ComboBoxItem Content="44100 Hz"/>
                                </ComboBox>
                                <TextBlock Text="最小时长 (秒)" Foreground="{StaticResource TextMuted}"/>
                                <TextBox Height="32" Text="5" Margin="0,4,0,10"/>
                                <TextBlock Text="最大时长 (秒)" Foreground="{StaticResource TextMuted}"/>
                                <TextBox Height="32" Text="15" Margin="0,4,0,10"/>
                                <CheckBox Content="自动标准化响度" IsChecked="True" Margin="0,4,0,4"/>
                                <CheckBox Content="切分失败自动标记" IsChecked="True" Margin="0,4,0,4"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="ASR / 文本处理">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Qwen3-ASR（本地）" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
                                <TextBlock Text="仅使用本地 Qwen3-ASR 模型，无需云端。" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="BtnStartASR" Style="{StaticResource PrimaryButton}" Content="开始识别 (Qwen3)" Width="150" Margin="0,0,8,0" Click="BtnStartASR_Click"/>
                                    <Button Style="{StaticResource GhostButton}" Content="从输出目录刷新结果" Width="140" Margin="0,0,8,0" Click="BtnRefreshASRResults_Click"/>
                                    <Button x:Name="BtnOpenASRDebug" Style="{StaticResource GhostButton}" Content="打开 ASR 输出目录" Width="160" Margin="0,0,8,0" Click="BtnOpenASRDebug_Click" ToolTip="打开当前选择的 ASR 输出文件夹"/>
                                    <Button Style="{StaticResource GhostButton}" Content="在命令行窗口运行 ASR" Width="160" Margin="0,0,8,0" Click="BtnRunASRInConsole_Click" ToolTip="弹出命令行窗口执行 ASR，便于查看实时输出"/>
                                    <Button x:Name="BtnExportToFADir" Style="{StaticResource SuccessButton}" Content="导出到 FA 目录" Width="120" Click="BtnExportToFADir_Click" ToolTip="将 WAV 和 .lab 文件复制到 fa_input 目录，供 FA 对齐使用"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="识别语言:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="CmbAsrLanguage" Width="120" Height="28" VerticalContentAlignment="Center" SelectedIndex="1" ToolTip="自动检测由模型判断，指定语言可提高切片/短音频识别率">
                                        <ComboBoxItem Content="自动检测" Tag="auto"/>
                                        <ComboBoxItem Content="中文" Tag="Chinese"/>
                                        <ComboBoxItem Content="English" Tag="English"/>
                                    </ComboBox>
                                    <TextBlock Text="推理后端:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                    <ComboBox x:Name="CmbAsrBackend" Width="120" Height="28" VerticalContentAlignment="Center" SelectedIndex="0" ToolTip="ONNX：纯 Go 推理，需 qwen3-asr-*-onnx 目录；Python：需 qwen3asrinfer 目录含 .venv 和 main.py">
                                        <ComboBoxItem Content="ONNX（Go）" Tag="onnx"/>
                                        <ComboBoxItem Content="Python" Tag="python"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="输入文件夹:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TxtInputDir" Width="280" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="70" Margin="8,0,0,0" Click="BtnBrowseInput_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="输出文件夹:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TxtOutputDir" Width="280" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="70" Margin="8,0,0,0" Click="BtnBrowseOutput_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtASRStatus" Text="就绪" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="ProgressASR" Height="6" Margin="0,0,0,8" Visibility="Collapsed" IsIndeterminate="True"/>
                                <DataGrid x:Name="GridASRResults" ItemsSource="{Binding ASRResults}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="切片" Width="1*" Binding="{Binding SliceId}"/>
                                        <DataGridTextColumn Header="原始识别文本" Width="2*" Binding="{Binding RawText}"/>
                                        <DataGridTextColumn Header="拼音（无标点无调）" Width="2*" Binding="{Binding Pinyin}"/>
                                        <DataGridTextColumn Header="处理后文本" Width="2*" Binding="{Binding ProcessedText}"/>
                                        <DataGridTextColumn Header="语言" Width="0.6*" Binding="{Binding Language}"/>
                                        <DataGridTextColumn Header="置信度" Width="0.6*" Binding="{Binding Confidence}"/>
                                        <DataGridTextColumn Header="状态" Width="0.6*" Binding="{Binding Status}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="说明" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="本地 Qwen3-ASR，支持两种推理后端：" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                                <TextBlock Text="ONNX（Go）后端：" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <TextBlock Text="• DataForgeLite.exe（Go 后端）" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                <TextBlock Text="• exe 同目录或上级目录下的 qwen3-asr-*-onnx 目录（含 encoder.onnx、decoder_init.onnx、embed_tokens.bin）" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="• onnxruntime.dll（与 exe 同目录）" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                <TextBlock Text="Python 后端：" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Text="• exe 同目录或上级目录下的 qwen3asrinfer 目录" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                <TextBlock Text="• qwen3asrinfer 目录内需含 main.py 与 .venv（已安装依赖的虚拟环境）" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="HubertFA 对齐">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="HubertFA 强制对齐" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
                                <TextBlock Text="本地 ONNX 音素级强制对齐，需配置 HubertFA 模型目录。" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="模型目录:" VerticalAlignment="Center" Width="90"/>
                                    <TextBox x:Name="TxtFAModelDir" Width="260" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseFAModelDir_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="输入目录（切分音频+同名.lab）:" VerticalAlignment="Center" Width="220"/>
                                    <TextBox x:Name="TxtFAInputWavs" Width="130" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseFAInputWavs_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="输出目录（TextGrid）:" VerticalAlignment="Center" Width="160"/>
                                    <TextBox x:Name="TxtFAOutputTg" Width="190" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseFAOutputTg_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="BtnStartFA" Style="{StaticResource PrimaryButton}" Content="开始对齐" Width="120" Click="BtnStartFA_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtFAStatus" Text="" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="ProgressFA" Height="6" Margin="0,0,0,8" Visibility="Collapsed" IsIndeterminate="True"/>
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Non-speech phonemes:" Margin="0,0,0,4"/>
                                    <WrapPanel x:Name="PanelFaNonLexical" Orientation="Horizontal" Margin="0,0,0,8"/>
                                    <TextBlock Text="Language:" Margin="0,0,0,4"/>
                                    <WrapPanel x:Name="PanelFaLanguages" Orientation="Horizontal"/>
                                    <TextBlock x:Name="TxtFAModelInfo" Text="" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="说明" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Foreground="{StaticResource TextMuted}" TextWrapping="Wrap">
                                    <Run Text="HubertFA 为本地 ONNX 强制对齐。模型目录自动填为 hfa_model。"/>
                                    <LineBreak/>
                                    <Run Text="输入目录：包含切分后的音频与 ASR 生成的同名 .lab 文件。"/>
                                    <LineBreak/>
                                    <Run Text="输出目录：写入与音频同名的 .TextGrid 文件。"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="标注合并/拆分">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="标注合并 / 拆分" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
                                <!-- 合并 -->
                                <TextBlock Text="合并（Combine）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="WAV 目录:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="TxtCombineWavs" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseCombineWavs_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="TextGrid 目录:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="TxtCombineTg" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseCombineTg_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="输出目录:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="TxtCombineOut" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseCombineOut_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="后缀模式:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="TxtCombineSuffix" Width="120" Height="28" VerticalContentAlignment="Center" Text="_\d+"/>
                                    <CheckBox x:Name="ChkCombineOverwrite" Content="覆盖已有文件" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="BtnCombineTg" Style="{StaticResource PrimaryButton}" Content="开始合并" Width="120" Click="BtnCombineTg_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtCombineStatus" Text="" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                <!-- 拆分 -->
                                <TextBlock Text="拆分（Slice）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="输入目录:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="TxtSliceIn" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseSliceIn_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="输出目录:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="TxtSliceOut" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseSliceOut_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="编号位数:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="TxtSliceDigits" Width="60" Height="28" VerticalContentAlignment="Center" Text="3"/>
                                    <CheckBox x:Name="ChkSlicePreserveName" Content="保留句子名" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <CheckBox x:Name="ChkSliceOverwrite" Content="覆盖已有文件" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="BtnSliceTg" Style="{StaticResource PrimaryButton}" Content="开始拆分" Width="120" Click="BtnSliceTg_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtSliceStatus" Text="" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="说明" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Foreground="{StaticResource TextMuted}" TextWrapping="Wrap">
                                    <Run Text="合并：将多段 2-tier TextGrid（words+phones）和对应 WAV 合并为一个 3-tier TextGrid（sentences+words+phones）和长音频。"/>
                                    <LineBreak/><LineBreak/>
                                    <Run Text="拆分：将 3-tier TextGrid 和长音频按 sentences tier 拆分为多段 2-tier TextGrid 和短音频。"/>
                                    <LineBreak/><LineBreak/>
                                    <Run Text="后缀模式：用于识别同一组文件的正则后缀，默认 _\d+（如 name_001, name_002）。"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="导出">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="导出数据集" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="输入目录:" VerticalAlignment="Center" Width="80"/>
                                    <TextBox x:Name="TxtExportInDir" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseExportInDir_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="输出目录:" VerticalAlignment="Center" Width="80"/>
                                    <TextBox x:Name="TxtExportOut" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseExportOut_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="词典文件:" VerticalAlignment="Center" Width="80"/>
                                    <TextBox x:Name="TxtAddPhNumDict" Width="220" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseAddPhNumDict_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="BtnExportDataset" Style="{StaticResource SuccessButton}" Content="导出数据集" Width="120" Click="BtnExportDataset_Click"/>
                                    <CheckBox x:Name="ChkExportRunGameAlign" Content="导出后运行 GAME Align（生成 note_seq/note_dur）" Margin="16,0,0,0" VerticalAlignment="Center" IsChecked="True"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtExportStatus" Text="" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,14,0,14"/>
                                <TextBlock Text="手动运行 GAME Align（Go 实现）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="csv1:" VerticalAlignment="Center" Width="80"/>
                                    <TextBox x:Name="TxtGameAlignCsv1" Width="380" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="选择..." Width="60" Margin="4,0,0,0" Click="BtnBrowseGameAlignCsv1_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="csv2:" VerticalAlignment="Center" Width="80"/>
                                    <TextBox x:Name="TxtGameAlignCsv2" Width="380" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="保存..." Width="60" Margin="4,0,0,0" Click="BtnBrowseGameAlignCsv2_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="wavs:" VerticalAlignment="Center" Width="80"/>
                                    <TextBox x:Name="TxtGameAlignWavsDir" Width="380" Height="28" VerticalContentAlignment="Center"/>
                                    <Button Content="浏览..." Width="60" Margin="4,0,0,0" Click="BtnBrowseGameAlignWavsDir_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button x:Name="BtnRunGameAlignGo" Style="{StaticResource GhostButton}" Content="运行 GAME Align" Width="120" Click="BtnRunGameAlignGo_Click"/>
                                    <TextBlock Text="输出：note_seq / note_dur 写入 csv2" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="导出参数" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="导出格式" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="transcriptions" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <TextBlock Text="输出 transcriptions.csv，包含 name / ph_seq / ph_dur 三列。" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,1,1,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatusBar" Text="就绪 - 请选择文件夹导入音频或直接填写 ASR/导出路径" VerticalAlignment="Center" Foreground="{StaticResource TextMain}"/>
                <TextBlock Grid.Column="1" Text="WPF / .NET 4.6.2" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
